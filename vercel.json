{
  "build": {
    "env": {
      "CARGO_HOME": "/vercel/.cargo",
      "RUSTUP_HOME": "/vercel/.rustup",
      "RUSTUP_INIT_SKIP_PATH_CHECK": "1",
      "RUSTUP_INIT_SKIP_PATH_MODIFICATION": "1",
      "RUSTUP_INIT_SKIP_RCFILE": "1",
      "RUSTUP_INIT_SKIP_SUDO_CHECK": "1"
    }
  },
  "buildCommand": "bash scripts/build-vercel.sh",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "redirects": [
    { "source": "/usdg", "destination": "/paxos", "permanent": true }
  ],
  "crons": [
    { "path": "/api/redeploy", "schedule": "0 6 * * *" }
  ]
}
